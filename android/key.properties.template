# Moss 智能管家 - 签名配置模板
# 
# 使用说明:
# 1. 复制此文件为 key.properties
# 2. 生成签名密钥:
#    keytool -genkey -v -keystore moss-release.keystore -alias moss -keyalg RSA -keysize 2048 -validity 10000
# 3. 填写以下配置
# 4. 将 key.properties 添加到 .gitignore
#
# 注意: 请勿将真实的密钥信息提交到版本控制!

storePassword=your_store_password
keyPassword=your_key_password
keyAlias=moss
storeFile=../moss-release.keystore
